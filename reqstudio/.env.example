# ============================================
# ReqStudio Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- API Configuration ---
API_PORT=8000
API_HOST=0.0.0.0
DEBUG=true

# --- Database (PostgreSQL) ---
POSTGRES_USER=reqstudio
POSTGRES_PASSWORD=reqstudio
POSTGRES_DB=reqstudio
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://reqstudio:reqstudio@db:5432/reqstudio
DATABASE_TEST_URL=postgresql+asyncpg://reqstudio:reqstudio@db:5432/reqstudio_test

# --- CORS ---
# Incluir todas as portas usadas em desenvolvimento (Docker + Vite local)
# Porta 5174: frontend no Docker
# Porta 5175: vite dev server local (auto-detectado se 5174 ocupado)
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5175

# --- Frontend ---
FRONTEND_PORT=5174

# --- JWT ---
# Gere uma chave segura: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
